{
  "expo": {
    "name": "CrypGo Driver",
    "slug": "crypgo-driver",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "crypgo-driver",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "bg.crypgo.driver",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "CrypGo Driver използва GPS за да стриймва позицията ви към пътниците.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "CrypGo Driver използва GPS на заден план за да следи активния курс.",
        "UIBackgroundModes": ["location", "fetch"]
      }
    },
    "android": {
      "package": "bg.crypgo.driver",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#1a1a2e"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "CrypGo Driver uses GPS to stream your position to passengers.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      "expo-task-manager",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#F7931A",
          "defaultChannel": "default"
        }
      ]
    ],
    "extra": {
      "apiBaseUrl": "http://10.0.2.2:3000",
      "eas": {
        "projectId": "crypgo-driver"
      }
    }
  }
}
